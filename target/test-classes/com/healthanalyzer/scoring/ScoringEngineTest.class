   void testArchivedRepositoryIsDead() {
      RepoInfo repoInfo = new RepoInfo("owner/archived-repo", "An archived repository", "Java", 500, 100, 20, 0, 50, Instant.now().minus(1000L, ChronoUnit.DAYS), Instant.now().minus(500L, ChronoUnit.DAYS), Instant.now().minus(500L, ChronoUnit.DAYS), true, false, false, "MIT", List.of(), "main", (String)null);
