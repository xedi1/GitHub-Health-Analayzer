               githubToken = System.getenv("GITHUB_TOKEN");
               if (githubToken != null && !githubToken.isEmpty()) {
                  System.out.println("\u001b[92m✓ \u001b[97mUsing GitHub token from environment\u001b[0m");
               }
            }

            AppConfig config = AppConfig.builder().githubToken(githubToken).verboseLogging(this.verbose).defaultFormat(OutputFormat.fromString(this.format)).build();
            HealthAnalysisService service = new HealthAnalysisService(config);
            ReportService reportService = new ReportService();

            Integer var19;
            try {
               try {
                  List<HealthReport> reports = new ArrayList();
                  int success = 0;
                  int failed = 0;

                  for(String repoPath : repos) {
                     repoPath = repoPath.trim();
                     if (!repoPath.isEmpty() && !repoPath.startsWith("#")) {
                        try {
