         }).count();
         int recentlyOpened = (int)openPRs.stream().filter((pr) -> {
            Instant created = this.parseDate(pr.get("created_at"));
            return created != null && created.isAfter(thirtyDaysAgo);
         }).count();
         int stalePRs = (int)openPRs.stream().filter((pr) -> {
            Instant updated = this.parseDate(pr.get("updated_at"));
            return updated != null && Duration.between(updated, Instant.now()).toDays() > 30L;
         }).count();
         double mergeRate = closedPRs.isEmpty() ? (double)0.0F : (double)recentlyMerged / (double)(recentlyMerged + closedPRs.size());
