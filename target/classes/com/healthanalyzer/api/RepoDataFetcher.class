   private List<PullRequestStats> fetchPullRequestStats(String owner, String repo) {
      try {
         List<JsonObject> openPRs = this.client.getPullRequests(owner, repo, "open");
         List<JsonObject> closedPRs = this.client.getPullRequests(owner, repo, "closed");
         Instant thirtyDaysAgo = Instant.now().minus(Duration.ofDays(30L));
         int recentlyMerged = (int)closedPRs.stream().filter((pr) -> {
            if (pr.has("merged_at") && !pr.get("merged_at").isJsonNull()) {
               Instant mergedAt = this.parseDate(pr.get("merged_at"));
               return mergedAt != null && mergedAt.isAfter(thirtyDaysAgo);
